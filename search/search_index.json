{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u524d\u8a00","text":"<p>\u4f5c\u8005\u53d7\u5230\u5317\u5927\u6bb7\u65fb\u5b66\u957f\u5199\u7684CSDIY Wiki \u7684\u542f\u53d1\uff0c\u5e76\u53c2\u8003\u4e86\u5176\u5185\u5bb9\u7ec4\u7ec7\u65b9\u5f0f\uff0c\u6574\u7406\u4e86\u4e00\u4efd\u4ece\u9ad8\u8003\u7ed3\u675f\u5230\u5927\u5b66\u5f00\u5b66\u524d\u7684\u6307\u5357\uff0c\u8bb0\u5f55\u8fd9\u6bb5\u8fc7\u6e21\u671f\u91cc\u503c\u5f97\u4e86\u89e3\u548c\u63d0\u524d\u51c6\u5907\u7684\u4e8b\u60c5\u3002</p> <p>\u6211\u76ee\u524d\u5c31\u8bfb\u4e8e\u4e0a\u6d77\u4ea4\u901a\u5927\u5b66\u8ba1\u7b97\u673a\u79d1\u5b66\u4e0e\u6280\u672f\u4e13\u4e1a\uff0c\u8fd9\u7bc7\u6307\u5357\u6574\u7406\u4e86\u6211\u8fdb\u5165\u5927\u5b66\u4e00\u5e74\u4ee5\u6765\u8e29\u8fc7\u7684\u5751\u3001\u79ef\u7d2f\u7684\u7ecf\u9a8c\uff0c\u4ee5\u53ca\u4e00\u4e9b\u4e8b\u540e\u624d\u9010\u6e10\u610f\u8bc6\u5230\u7684\u95ee\u9898\u3002</p> <p>\u8fd9\u7bc7\u6587\u7ae0\u4e5f\u7279\u522b\u5199\u7ed9\u6211\u7684\u6bcd\u6821--\u606d\u57ce\u4e2d\u5b66\u7684\u5b66\u5f1f\u5b66\u59b9\u4eec\uff0c\u5e0c\u671b\u5b83\u80fd\u4e3a\u4f60\u4eec\u63a5\u4e0b\u6765\u7684\u9009\u62e9\u3001\u5f00\u5b66\u524d\u7684\u51c6\u5907\u548c\u4e4b\u540e\u7684\u5927\u5b66\u751f\u6d3b\u63d0\u4f9b\u4e00\u70b9\u5e2e\u52a9\u3002</p> <p>\u4e3a\u4e86\u65b9\u4fbf\u9605\u8bfb\uff0c\u672c\u6307\u5357\u6309\u7167\u9ad8\u8003\u7ed3\u675f\u540e\u7684\u65f6\u95f4\u987a\u5e8f\uff0c\u4e3b\u8981\u5206\u4e3a\u4e09\u4e2a\u9636\u6bb5\uff1a</p>"},{"location":"#69-625","title":"\u4e00\u3001\u9ad8\u8003\u7ed3\u675f\u81f3\u51fa\u5206\u524d\uff086\u67089\u53f7--6\u670825\u53f7\uff09","text":"<p>\u521a\u9ad8\u8003\u5b8c\u5927\u5bb6\u90fd\u4f1a\u611f\u5230\u8eab\u5fc3\u4ff1\u75b2\uff0c\u8fd9\u4e00\u9636\u6bb5\u53ef\u4ee5\u5148\u9002\u5f53\u4f11\u606f\u3001\u8c03\u6574\u72b6\u6001\uff0c\u540c\u65f6\u5f00\u59cb\u4e86\u89e3\u4e0d\u540c\u4e13\u4e1a\u7684\u5b66\u4e60\u5185\u5bb9\u3001\u57f9\u517b\u65b9\u5f0f\u548c\u53d1\u5c55\u65b9\u5411\uff0c\u521d\u6b65\u601d\u8003\u81ea\u5df1\u5bf9\u4e13\u4e1a\u3001\u5b66\u6821\u548c\u57ce\u5e02\u7684\u9700\u6c42\uff0c\u4e3a\u4e4b\u540e\u7684\u5fd7\u613f\u586b\u62a5\u505a\u597d\u51c6\u5907\u3002</p> <p>\u8fd9\u4e00\u90e8\u5206\u4e3b\u8981\u5305\u62ec\uff1a</p> <ul> <li>\u4e13\u4e1a\u8ba4\u77e5</li> <li>\u4fe1\u606f\u641c\u96c6\u65b9\u6cd5</li> <li>\u5b66\u6821\u4e0e\u4e13\u4e1a\u7684\u521d\u6b65\u7b5b\u9009</li> </ul>"},{"location":"#625-718","title":"\u4e8c\u3001\u51fa\u5206\u540e\u81f3\u5f55\u53d6\u7ed3\u679c\u786e\u5b9a\u524d\uff086\u670825\u53f7--7\u670818\u53f7\uff09","text":"<p>\u6210\u7ee9\u548c\u4f4d\u6b21\u516c\u5e03\u540e\uff0c\u5c31\u8fdb\u5165\u4e86\u5fd7\u613f\u586b\u62a5\u7684\u6838\u5fc3\u9636\u6bb5\u3002\u9700\u8981\u6839\u636e\u81ea\u5df1\u7684\u5b9e\u9645\u4f4d\u6b21\uff0c\u8fdb\u4e00\u6b65\u6bd4\u8f83\u5b66\u6821\u3001\u4e13\u4e1a\u548c\u57ce\u5e02\uff0c\u4e86\u89e3\u62db\u751f\u8ba1\u5212\u3001\u4e13\u4e1a\u7ec4\u3001\u8c03\u5242\u89c4\u5219\u548c\u76f8\u5173\u9650\u5236\uff0c\u5e76\u9010\u6b65\u5f62\u6210\u6700\u7ec8\u7684\u5fd7\u613f\u65b9\u6848\u3002</p> <p>\u8fd9\u4e00\u90e8\u5206\u4e3b\u8981\u5305\u62ec\uff1a</p> <ul> <li>\u5fd7\u613f\u586b\u62a5\u7684\u57fa\u672c\u601d\u8def</li> <li>\u5b66\u6821\u3001\u4e13\u4e1a\u548c\u57ce\u5e02\u4e4b\u95f4\u7684\u6743\u8861</li> <li>\u6211\u7684\u5fd7\u613f\u586b\u62a5\u7ecf\u5386</li> <li>\u9ad8\u6821\u62db\u751f\u54a8\u8be2\u4e0e\u4fe1\u606f\u6838\u5b9e</li> </ul>"},{"location":"#718-824","title":"\u4e09\u3001\u5f55\u53d6\u7ed3\u679c\u786e\u5b9a\u540e\u81f3\u5927\u5b66\u5f00\u5b66\u524d\uff087\u670818\u53f7--8\u670824\u53f7\uff09","text":"<p>\u786e\u5b9a\u5f55\u53d6\u5b66\u6821\u548c\u4e13\u4e1a\u540e\uff0c\u53ef\u4ee5\u9010\u6e10\u5f00\u59cb\u51c6\u5907\u5927\u5b66\u9636\u6bb5\u7684\u5b66\u4e60\u4e0e\u751f\u6d3b\u3002\u8fd9\u4e2a\u9636\u6bb5\u4e0d\u5fc5\u6025\u7740\u63d0\u524d\u5b66\u5b8c\u5927\u5b66\u8bfe\u7a0b\uff0c\u66f4\u91cd\u8981\u7684\u662f\u4e86\u89e3\u5927\u5b66\u4e0e\u9ad8\u4e2d\u5728\u5b66\u4e60\u65b9\u5f0f\u4e0a\u7684\u5dee\u5f02\uff0c\u638c\u63e1\u4e00\u4e9b\u57fa\u672c\u5de5\u5177\u548c\u751f\u6d3b\u6280\u80fd\uff0c\u8ba9\u81ea\u5df1\u8fdb\u5165\u5927\u5b66\u540e\u5c11\u4e00\u4e9b\u624b\u5fd9\u811a\u4e71\u3002</p> <p>\u8fd9\u4e00\u90e8\u5206\u4e3b\u8981\u5305\u62ec\uff1a</p> <ul> <li>\u7535\u8111\u548c\u8f6f\u4ef6\u51c6\u5907</li> <li>\u82f1\u8bed\u5b66\u4e60</li> <li>\u7f16\u7a0b\u5165\u95e8</li> <li>\u5927\u5b66\u751f\u6d3b\u51c6\u5907</li> <li>\u5f00\u5b66\u9632\u5751\u4e0e\u5b89\u5168\u63d0\u9192</li> <li>\u5199\u7ed9\u8ba1\u7b97\u673a\u4e13\u4e1a\u65b0\u751f\u7684\u4e00\u4e9b\u5efa\u8bae</li> </ul> <p>\u9700\u8981\u8bf4\u660e\u7684\u662f\uff0c\u8fd9\u4e09\u4e2a\u9636\u6bb5\u5e76\u4e0d\u662f\u5b8c\u5168\u5206\u5272\u7684\u3002\u4f8b\u5982\uff0c\u4e13\u4e1a\u8ba4\u77e5\u53ef\u4ee5\u4e00\u76f4\u6301\u7eed\u5230\u5fd7\u613f\u586b\u62a5\u7ed3\u675f\uff0c\u82f1\u8bed\u548c\u7f16\u7a0b\u5b66\u4e60\u4e5f\u4e0d\u5fc5\u7b49\u5230\u5f55\u53d6\u540e\u624d\u5f00\u59cb\u3002\u8fd9\u6837\u7684\u5212\u5206\u4e3b\u8981\u662f\u4e3a\u4e86\u5e2e\u52a9\u5927\u5bb6\u6839\u636e\u81ea\u5df1\u76ee\u524d\u6240\u5904\u7684\u9636\u6bb5\uff0c\u66f4\u5feb\u5730\u627e\u5230\u9700\u8981\u7684\u5185\u5bb9\u3002</p> <p>\u8fd9\u4e0d\u662f\u4e00\u4efd\u9002\u7528\u4e8e\u6240\u6709\u4eba\u7684\u6807\u51c6\u7b54\u6848\uff0c\u800c\u662f\u6211\u6839\u636e\u4e2a\u4eba\u7ecf\u5386\u6574\u7406\u7684\u4e00\u4efd\u53c2\u8003\u3002\u4e0d\u540c\u5b66\u6821\u3001\u4e13\u4e1a\u548c\u4e2a\u4eba\u60c5\u51b5\u53ef\u80fd\u5b58\u5728\u5f88\u5927\u5dee\u5f02\uff0c\u56e0\u6b64\u6d89\u53ca\u62db\u751f\u653f\u7b56\u3001\u57f9\u517b\u65b9\u6848\u7b49\u5185\u5bb9\u65f6\uff0c\u8bf7\u4ee5\u5b66\u6821\u548c\u6709\u5173\u90e8\u95e8\u53d1\u5e03\u7684\u5b98\u65b9\u4fe1\u606f\u4e3a\u51c6\u3002</p> <p>\u5982\u679c\u4f60\u5bf9\u6587\u7ae0\u6709\u5efa\u8bae\uff0c\u6b22\u8fce\u901a\u8fc7\u90ae\u7bb1\u4e0e\u6211\u4ea4\u6d41\uff1a18077329798@sjtu.edu.cn</p>"},{"location":"#_2","title":"\u4e3a\u4ec0\u4e48\u5199\u8fd9\u7bc7\u6587\u7ae0","text":"<p>\u6211\u6765\u81ea\u5e7f\u897f\u7684\u4e00\u5ea7\u5c0f\u53bf\u57ce\uff0c\u4eb2\u8eab\u7ecf\u5386\u8fc7\u4ece\u53bf\u57ce\u8d70\u5411\u66f4\u5927\u57ce\u5e02\u7684\u8fc7\u7a0b\uff0c\u56e0\u6b64\u660e\u767d\u8fd9\u6761\u8def\u5e76\u4e0d\u5bb9\u6613\u3002</p> <p>\u9ad8\u8003\u540e\u7684\u6691\u5047\u91cc\uff0c\u6211\u66fe\u4e0e\u51e0\u4f4d\u9ad8\u6821\u8001\u5e08\u4ea4\u6d41\u3002\u56e0\u4e3a\u5f53\u65f6\u9009\u62e9\u4e86\u5b66\u4e60\u8ba1\u7b97\u673a\u4e13\u4e1a\uff0c\u4ed6\u4eec\u5411\u6211\u4ecb\u7ecd\u4e86\u5927\u5b66\u7684\u5b66\u4e60\u65b9\u5f0f\uff0c\u4e5f\u5efa\u8bae\u6211\u63d0\u524d\u63a5\u89e6\u4e00\u4e9b\u8ba1\u7b97\u673a\u5165\u95e8\u8bfe\u7a0b\uff0c\u4f8b\u5982\u54c8\u4f5b\u5927\u5b66\u7684 CS50 \u548c\u52a0\u5dde\u5927\u5b66\u4f2f\u514b\u5229\u5206\u6821\u7684 CS61A\u3002</p> <p>\u4f46\u5f53\u65f6\u7684\u6211\u5e76\u6ca1\u6709\u771f\u6b63\u7406\u89e3\u8fd9\u4e9b\u5efa\u8bae\u7684\u91cd\u8981\u6027\uff0c\u53ea\u662f\u7b80\u5355\u5730\u542c\u8fc7\uff0c\u5374\u6ca1\u6709\u8fdb\u4e00\u6b65\u4e86\u89e3\u548c\u884c\u52a8\u3002\u8fdb\u5165\u5927\u5b66\u540e\uff0c\u9762\u5bf9\u66f4\u5feb\u7684\u8bfe\u7a0b\u8282\u594f\u3001\u66f4\u9ad8\u7684\u81ea\u4e3b\u5b66\u4e60\u8981\u6c42\u4ee5\u53ca\u964c\u751f\u7684\u4e13\u4e1a\u5185\u5bb9\uff0c\u6211\u4e00\u5ea6\u611f\u5230\u5f88\u4e0d\u9002\u5e94\u3002\u90a3\u6bb5\u65f6\u95f4\u91cc\uff0c\u6211\u7ecf\u5e38\u4f1a\u60f3\uff1a\u5047\u5982\u80fd\u591f\u56de\u5230\u9ad8\u8003\u540e\u7684\u90a3\u4e2a\u6691\u5047\uff0c\u6211\u4f1a\u600e\u6837\u91cd\u65b0\u5b89\u6392\u8fd9\u6bb5\u65f6\u95f4\uff0c\u53c8\u4f1a\u63d0\u524d\u505a\u54ea\u4e9b\u51c6\u5907\u3002</p> <p>\u5f53\u7136\uff0c\u8fd9\u5e76\u4e0d\u662f\u8bf4\u6bcf\u4e2a\u4eba\u90fd\u5fc5\u987b\u5728\u5f00\u5b66\u524d\u5b66\u5b8c\u51e0\u95e8\u5927\u5b66\u8bfe\u7a0b\u3002\u771f\u6b63\u8ba9\u6211\u9057\u61be\u7684\uff0c\u5e76\u4e0d\u662f\u6ca1\u6709\u63d0\u524d\u638c\u63e1\u591a\u5c11\u77e5\u8bc6\uff0c\u800c\u662f\u6ca1\u6709\u53ca\u65e9\u8ba4\u8bc6\u5230\u5927\u5b66\u4e0e\u9ad8\u4e2d\u5728\u5b66\u4e60\u65b9\u5f0f\u4e0a\u7684\u5dee\u5f02\uff0c\u4e5f\u6ca1\u6709\u5145\u5206\u5229\u7528\u5f53\u65f6\u80fd\u591f\u63a5\u89e6\u5230\u7684\u4fe1\u606f\u548c\u5efa\u8bae\u3002</p> <p>\u8fdb\u5165\u5927\u5b66\u540e\uff0c\u6211\u9010\u6e10\u610f\u8bc6\u5230\uff0c\u4e0d\u540c\u5730\u533a\u5728\u6559\u80b2\u8d44\u6e90\u3001\u4fe1\u606f\u83b7\u53d6\u6e20\u9053\u548c\u89c6\u91ce\u65b9\u9762\u5b58\u5728\u7740\u4e0d\u5c0f\u7684\u5dee\u8ddd\u3002\u5f88\u591a\u65f6\u5019\uff0c\u5e76\u4e0d\u662f\u6211\u4eec\u4e0d\u613f\u610f\u52aa\u529b\uff0c\u800c\u662f\u4e0d\u77e5\u9053\u5e94\u8be5\u53bb\u54ea\u91cc\u5bfb\u627e\u4fe1\u606f\uff0c\u4e5f\u4e0d\u77e5\u9053\u6709\u54ea\u4e9b\u53ef\u4ee5\u501f\u9274\u7684\u65b9\u6cd5\u3002\u8fd9\u4e9b\u4fe1\u606f\u4e0a\u7684\u5dee\u8ddd\uff0c\u5f88\u5bb9\u6613\u8ba9\u4eba\u5728\u9762\u5bf9\u5fd7\u613f\u586b\u62a5\u3001\u4e13\u4e1a\u9009\u62e9\u548c\u5927\u5b66\u751f\u6d3b\u65f6\u611f\u5230\u8ff7\u832b\u548c\u65e0\u52a9\u3002</p> <p>\u8fc7\u53bb\u4e00\u5e74\u91cc\uff0c\u6211\u4e5f\u56e0\u4e3a\u4fe1\u606f\u4e0d\u8db3\u3001\u7f3a\u5c11\u7ecf\u9a8c\u800c\u8d70\u8fc7\u4e00\u4e9b\u5f2f\u8def\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u901a\u8fc7\u4e0e\u8001\u5e08\u3001\u5b66\u957f\u5b66\u59d0\u548c\u8eab\u8fb9\u540c\u5b66\u7684\u4ea4\u6d41\uff0c\u6211\u9010\u6e10\u79ef\u7d2f\u4e86\u4e00\u4e9b\u7ecf\u9a8c\uff0c\u5bf9\u5927\u5b66\u5b66\u4e60\u548c\u751f\u6d3b\u6709\u4e86\u66f4\u52a0\u5177\u4f53\u7684\u8ba4\u8bc6\u3002</p> <p>\u56e0\u6b64\uff0c\u6211\u60f3\u628a\u81ea\u5df1\u4e86\u89e3\u5230\u7684\u4fe1\u606f\u3001\u8e29\u8fc7\u7684\u5751\u548c\u5f97\u5230\u7684\u611f\u609f\u6574\u7406\u4e0b\u6765\uff0c\u5206\u4eab\u7ed9\u5b66\u5f1f\u5b66\u59b9\u4eec\u3002\u8fd9\u4e9b\u5185\u5bb9\u6216\u8bb8\u5e76\u4e0d\u9002\u7528\u4e8e\u6bcf\u4e00\u4e2a\u4eba\uff0c\u4f46\u53ea\u8981\u80fd\u4e3a\u4f60\u4eec\u4e4b\u540e\u7684\u9009\u62e9\u548c\u5927\u5b66\u751f\u6d3b\u63d0\u4f9b\u4e00\u70b9\u5e2e\u52a9\uff0c\u8fd9\u7bc7\u6587\u7ae0\u5c31\u6709\u4e86\u610f\u4e49\u3002</p>"},{"location":"#_3","title":"\u8fd9\u7bc7\u6587\u7ae0\u9002\u5408\u8c01","text":"<p>\u8fd9\u7bc7\u6307\u5357\u4e3b\u8981\u5199\u7ed9\u521a\u521a\u7ed3\u675f\u9ad8\u8003\u3001\u5373\u5c06\u8fdb\u5165\u5927\u5b66\u7684\u540c\u5b66\u3002\u5982\u679c\u4f60\u8fd8\u4e0d\u77e5\u9053\u5f00\u5b66\u524d\u53ef\u4ee5\u505a\u54ea\u4e9b\u51c6\u5907\uff0c\u6216\u8005\u5e0c\u671b\u63d0\u524d\u4e86\u89e3\u5fd7\u613f\u586b\u62a5\u3001\u4e13\u4e1a\u9009\u62e9\u3001\u5927\u5b66\u5b66\u4e60\u548c\u6821\u56ed\u751f\u6d3b\u7b49\u65b9\u9762\u7684\u4fe1\u606f\uff0c\u53ef\u4ee5\u628a\u8fd9\u7bc7\u6587\u7ae0\u4f5c\u4e3a\u4e00\u4efd\u53c2\u8003\u3002</p> <p>\u6211\u76ee\u524d\u53ea\u5ea6\u8fc7\u4e86\u4e00\u5e74\u7684\u5927\u5b66\u751f\u6d3b\uff0c\u4e2a\u4eba\u7ecf\u5386\u548c\u89c6\u89d2\u96be\u514d\u5b58\u5728\u5c40\u9650\uff0c\u56e0\u6b64\u8fd9\u7bc7\u6307\u5357\u5e76\u4e0d\u662f\u4e00\u4efd\u9002\u7528\u4e8e\u6240\u6709\u4eba\u7684\u6807\u51c6\u7b54\u6848\u3002\u5bf9\u4e8e\u62db\u751f\u653f\u7b56\u3001\u57f9\u517b\u65b9\u6848\u548c\u5b66\u6821\u89c4\u5b9a\u7b49\u5185\u5bb9\uff0c\u4ecd\u5e94\u4ee5\u76f8\u5173\u90e8\u95e8\u548c\u5b66\u6821\u53d1\u5e03\u7684\u5b98\u65b9\u4fe1\u606f\u4e3a\u51c6\u3002</p> <p>\u6211\u4f1a\u5c3d\u91cf\u5206\u4eab\u81ea\u5df1\u4eb2\u8eab\u7ecf\u5386\u8fc7\u7684\u4e8b\u60c5\uff0c\u4e5f\u4f1a\u6574\u7406\u4e00\u4e9b\u8001\u5e08\u3001\u5b66\u957f\u5b66\u59d0\u548c\u5176\u4ed6\u53ef\u9760\u6765\u6e90\u63d0\u4f9b\u7684\u7ecf\u9a8c\u3002\u5e0c\u671b\u8fd9\u4e9b\u5185\u5bb9\u80fd\u591f\u5e2e\u52a9\u5927\u5bb6\u51cf\u5c11\u4e00\u4e9b\u56e0\u4e3a\u4fe1\u606f\u4e0d\u8db3\u800c\u4ea7\u751f\u7684\u8ff7\u832b\uff0c\u66f4\u52a0\u4ece\u5bb9\u5730\u5f00\u59cb\u5927\u5b66\u751f\u6d3b\u3002</p>"},{"location":"#_4","title":"\u7279\u522b\u9e23\u8c22","text":"<p>\u8fd9\u4efd\u6307\u5357\u80fd\u591f\u9010\u6e10\u6210\u5f62\uff0c\u79bb\u4e0d\u5f00\u8bb8\u591a\u4eba\u7684\u5e2e\u52a9\u3002</p> <p>\u9996\u5148\uff0c\u611f\u8c22 CSDIY Wiki \u53ca\u5176\u4f5c\u8005\u63d0\u4f9b\u7684\u542f\u53d1\uff0c\u8ba9\u6211\u610f\u8bc6\u5230\uff0c\u4e2a\u4eba\u5728\u5b66\u4e60\u548c\u6210\u957f\u8fc7\u7a0b\u4e2d\u79ef\u7d2f\u7684\u7ecf\u9a8c\uff0c\u4e5f\u53ef\u4ee5\u88ab\u8ba4\u771f\u6574\u7406\u5e76\u5206\u4eab\u7ed9\u540e\u6765\u8005\uff0c\u540c\u65f6\u6211\u4e5f\u5e0c\u671b\u5b66\u5f1f\u5b66\u59b9\u4eec\u5f18\u626c\u5f00\u6e90\u7684\u7cbe\u795e\u3002</p> <p>\u611f\u8c22\u8fc7\u53bb\u4e00\u5e74\u4e2d\u7ed9\u4e88\u6211\u5efa\u8bae\u548c\u5e2e\u52a9\u7684\u8001\u5e08\u3001\u5b66\u957f\u5b66\u59d0\u4ee5\u53ca\u540c\u5b66\u4eec\u3002\u65e0\u8bba\u662f\u5173\u4e8e\u5fd7\u613f\u586b\u62a5\u3001\u4e13\u4e1a\u9009\u62e9\u3001\u8bfe\u7a0b\u5b66\u4e60\uff0c\u8fd8\u662f\u5927\u5b66\u751f\u6d3b\u4e2d\u7684\u5404\u79cd\u95ee\u9898\uff0c\u4f60\u4eec\u7684\u7ecf\u9a8c\u548c\u63d0\u9192\u90fd\u8ba9\u6211\u5c11\u8d70\u4e86\u8bb8\u591a\u5f2f\u8def\uff0c\u4e5f\u6784\u6210\u4e86\u8fd9\u4efd\u6307\u5357\u7684\u91cd\u8981\u53c2\u8003\u3002</p> <p>\u4e5f\u611f\u8c22\u6211\u7684\u6bcd\u6821\u606d\u57ce\u4e2d\u5b66\uff0c\u4ee5\u53ca\u66fe\u7ecf\u6559\u5bfc\u548c\u5e2e\u52a9\u8fc7\u6211\u7684\u8001\u5e08\u4eec\u3002\u4f60\u4eec\u7684\u652f\u6301\u8ba9\u6211\u6709\u673a\u4f1a\u8d70\u5411\u66f4\u5927\u7684\u4e16\u754c\uff0c\u4e5f\u8ba9\u6211\u66f4\u52a0\u5e0c\u671b\u628a\u81ea\u5df1\u4e86\u89e3\u5230\u7684\u4fe1\u606f\u5206\u4eab\u7ed9\u5b66\u5f1f\u5b66\u59b9\u4eec\u3002</p> <p>\u6700\u540e\uff0c\u611f\u8c22\u6bcf\u4e00\u4f4d\u613f\u610f\u9605\u8bfb\u8fd9\u4efd\u6307\u5357\u3001\u63d0\u51fa\u5efa\u8bae\u6216\u5206\u4eab\u81ea\u8eab\u7ecf\u9a8c\u7684\u8bfb\u8005\u3002\u7531\u4e8e\u4e2a\u4eba\u7ecf\u5386\u548c\u80fd\u529b\u6709\u9650\uff0c\u6587\u7ae0\u4e2d\u96be\u514d\u5b58\u5728\u758f\u6f0f\u3002\u5982\u679c\u8fd9\u4efd\u6307\u5357\u80fd\u591f\u4e3a\u67d0\u4f4d\u540c\u5b66\u63d0\u4f9b\u4e00\u70b9\u5e2e\u52a9\uff0c\u6216\u8005\u8ba9\u5927\u5bb6\u5728\u9762\u5bf9\u9009\u62e9\u65f6\u5c11\u4e00\u4e9b\u8ff7\u832b\uff0c\u90a3\u4e48\u5b83\u5c31\u5df2\u7ecf\u5b9e\u73b0\u4e86\u6700\u521d\u7684\u610f\u4e49\u3002</p>"},{"location":"#_5","title":"\u8bf7\u4f5c\u8005\u559d\u676f\u4e0b\u5348\u8336","text":"<p>\u672c\u6307\u5357\u5c06\u6301\u7eed\u514d\u8d39\u5f00\u653e\u3002\u5982\u679c\u5b83\u5bf9\u4f60\u6709\u6240\u5e2e\u52a9\uff0c\u6b22\u8fce\u7ed9\u6211\u7684GitHub\u4ed3\u5e93\u70b9\u4e00\u4e2a Star\u3001\u63d0\u51fa\u4fee\u6539\u5efa\u8bae\uff0c\u6216\u8005\u81ea\u613f\u8bf7\u4f5c\u8005\u559d\u676f\u4e0b\u5348\u8336\u3002\u65e0\u8bba\u662f\u5426\u8d5e\u8d4f\uff0c\u90fd\u4e0d\u4f1a\u5f71\u54cd\u5185\u5bb9\u9605\u8bfb\u4e0e\u4ea4\u6d41\u3002</p> <p>\u6211\u7684GitHub\u4ed3\u5e93\u5730\u5740\uff1aDShuchang/preuni-guide</p> <p>\u8d5e\u8d4f\u5b8c\u5168\u81ea\u613f\uff0c\u8bf7\u5927\u5bb6\u91cf\u529b\u800c\u884c\u3002</p>"},{"location":"application/","title":"\u5fd7\u613f\u586b\u62a5\u603b\u89c8","text":"<p>\u9ad8\u8003\u7ed3\u675f\u540e\uff0c\u5927\u5bb6\u5f88\u5bb9\u6613\u88ab\u5404\u79cd\u5fd7\u613f\u586b\u62a5\u4fe1\u606f\u6df9\u6ca1\uff1a\u591a\u5c11\u5206\u80fd\u62a5\u4ec0\u4e48\u5b66\u6821\uff0c\u54ea\u4e9b\u4e13\u4e1a\u70ed\u95e8\uff0c\u54ea\u4e9b\u4e13\u4e1a\u4e0d\u80fd\u9009\uff0c\u5fd7\u613f\u5e94\u8be5\u600e\u6837\u5b89\u6392\u201c\u51b2\u3001\u7a33\u3001\u4fdd\u201d\u2026\u2026\u8fd9\u4e9b\u4fe1\u606f\u6709\u4e00\u5b9a\u53c2\u8003\u4ef7\u503c\uff0c\u4f46\u89c2\u70b9\u5f80\u5f80\u76f8\u4e92\u77db\u76fe\uff0c\u6700\u7ec8\u8fd8\u662f\u8981\u6839\u636e\u81ea\u5df1\u7684\u60c5\u51b5\u4f5c\u51fa\u5224\u65ad\u3002</p> <p>\u586b\u62a5\u5fd7\u613f\u65f6\uff0c\u9996\u5148\u9700\u8981\u660e\u786e\u4e2a\u4eba\u7684\u57fa\u672c\u6761\u4ef6\u548c\u9650\u5236\uff0c\u5305\u62ec\u6210\u7ee9\u4f4d\u6b21\u3001\u9009\u79d1\u8981\u6c42\u3001\u4f53\u68c0\u6761\u4ef6\u3001\u5bb6\u5ead\u7ecf\u6d4e\u60c5\u51b5\uff0c\u4ee5\u53ca\u81ea\u5df1\u80fd\u591f\u63a5\u53d7\u7684\u57ce\u5e02\u3001\u5b66\u8d39\u548c\u5b66\u4e60\u65b9\u5f0f\u3002\u5728\u8fd9\u4e9b\u6761\u4ef6\u4e4b\u5185\uff0c\u518d\u6bd4\u8f83\u4e13\u4e1a\u3001\u5b66\u6821\u548c\u57ce\u5e02\u3002</p> <p>\u5174\u8da3\u662f\u9009\u62e9\u4e13\u4e1a\u65f6\u7684\u91cd\u8981\u56e0\u7d20\uff0c\u4f46\u4e0d\u80fd\u53ea\u6839\u636e\u4e13\u4e1a\u540d\u79f0\u6216\u6a21\u7cca\u5370\u8c61\u5224\u65ad\u3002\u771f\u6b63\u9700\u8981\u4e86\u89e3\u7684\u662f\uff1a\u8fd9\u4e2a\u4e13\u4e1a\u672c\u79d1\u9636\u6bb5\u5b66\u4e60\u54ea\u4e9b\u8bfe\u7a0b\uff0c\u9700\u8981\u600e\u6837\u7684\u5b66\u79d1\u57fa\u7840\uff0c\u65e5\u5e38\u5b66\u4e60\u66f4\u504f\u5411\u5b9e\u9a8c\u3001\u7f16\u7a0b\u3001\u80cc\u8bf5\u8fd8\u662f\u5b9e\u8df5\uff0c\u4ee5\u53ca\u6bd5\u4e1a\u540e\u901a\u5e38\u6709\u54ea\u4e9b\u53d1\u5c55\u65b9\u5411\u3002</p> <p>\u5bf9\u4e13\u4e1a\u6709\u4e00\u5b9a\u5174\u8da3\uff0c\u901a\u5e38\u66f4\u5bb9\u6613\u5f62\u6210\u5b66\u4e60\u52a8\u529b\uff0c\u4f46\u5174\u8da3\u5e76\u4e0d\u610f\u5473\u7740\u5b66\u4e60\u8fc7\u7a0b\u59cb\u7ec8\u8f7b\u677e\u3002\u5373\u4f7f\u6682\u65f6\u6ca1\u6709\u975e\u5e38\u611f\u5174\u8da3\u7684\u65b9\u5411\uff0c\u4e5f\u4e0d\u8981\u7b80\u5355\u9009\u62e9\u6240\u8c13\u7684\u201c\u70ed\u95e8\u4e13\u4e1a\u201d\u3002\u884c\u4e1a\u70ed\u5ea6\u4f1a\u53d8\u5316\uff0c\u5f53\u524d\u70ed\u95e8\u4e0d\u4ee3\u8868\u51e0\u5e74\u540e\u4ecd\u7136\u70ed\u95e8\uff0c\u53d7\u5230\u653f\u7b56\u652f\u6301\u7684\u884c\u4e1a\u4e5f\u4e0d\u4ee3\u8868\u5176\u4e2d\u6240\u6709\u5c97\u4f4d\u90fd\u9002\u5408\u81ea\u5df1\u3002\u76f8\u6bd4\u8ffd\u9010\u70ed\u5ea6\uff0c\u66f4\u91cd\u8981\u7684\u662f\u786e\u8ba4\u81ea\u5df1\u80fd\u5426\u63a5\u53d7\u4e13\u4e1a\u7684\u5b66\u4e60\u5185\u5bb9\uff0c\u5e76\u4e86\u89e3\u5b83\u662f\u5426\u5177\u6709\u591a\u79cd\u53d1\u5c55\u8def\u5f84\u3002</p> <p>\u5b66\u6821\u5c42\u6b21\u3001\u4e13\u4e1a\u5339\u914d\u5ea6\u548c\u6240\u5728\u57ce\u5e02\u4e4b\u95f4\u6ca1\u6709\u9002\u7528\u4e8e\u6240\u6709\u4eba\u7684\u56fa\u5b9a\u6392\u5e8f\u3002\u6709\u4eba\u66f4\u91cd\u89c6\u5b66\u6821\u5e73\u53f0\u548c\u5347\u5b66\u673a\u4f1a\uff0c\u6709\u4eba\u66f4\u770b\u91cd\u4e13\u4e1a\u5b9e\u529b\uff0c\u4e5f\u6709\u4eba\u5e0c\u671b\u5c3d\u65e9\u63a5\u89e6\u76f8\u5173\u884c\u4e1a\u3002\u586b\u62a5\u524d\u53ef\u4ee5\u5148\u95ee\u81ea\u5df1\uff1a\u5728\u5b66\u6821\u3001\u4e13\u4e1a\u548c\u57ce\u5e02\u4e4b\u95f4\uff0c\u81ea\u5df1\u6700\u4e0d\u80fd\u63a5\u53d7\u7684\u7ed3\u679c\u662f\u4ec0\u4e48\uff0c\u53c8\u6700\u613f\u610f\u4e3a\u54ea\u4e00\u9879\u4f5c\u51fa\u59a5\u534f\uff1f</p> <p>\u4e00\u4e9b\u5b66\u6821\u7684\u90e8\u5206\u4e13\u4e1a\u5f55\u53d6\u4f4d\u6b21\u53ef\u80fd\u660e\u663e\u4f4e\u4e8e\u5b66\u6821\u6574\u4f53\u6c34\u5e73\uff0c\u4f46\u4e0d\u8981\u53ea\u628a\u8fd9\u79cd\u60c5\u51b5\u7406\u89e3\u4e3a\u201c\u4f4e\u5206\u51b2\u540d\u6821\u201d\u7684\u673a\u4f1a\u3002\u5929\u4e0b\u6ca1\u6709\u514d\u8d39\u7684\u5348\u9910\uff0c\u5206\u6570\u8f83\u4f4e\u5e26\u6765\u7684\u53ef\u80fd\u662f\u8f83\u4e3a\u51b7\u95e8\u5c0f\u4f17\u7684\u4e13\u4e1a\uff0c\u5728\u60f3\u8981\u4f4e\u5206\u51b2\u540d\u6821\u524d\u4e00\u5b9a\u8981\u5224\u65ad\u81ea\u5df1\u662f\u5426\u90fd\u80fd\u63a5\u53d7\u5c31\u8bfb\u8fd9\u4e9b\u51b7\u95e8\u7684\u4e13\u4e1a\u3002 \u5c24\u5176\u662f\u5728\u4ee5\u4e13\u4e1a\u7ec4\u4e3a\u5355\u4f4d\u586b\u62a5\u7684\u5730\u533a\uff0c\u4e0d\u8981\u53ea\u5173\u6ce8\u4e13\u4e1a\u7ec4\u91cc\u81ea\u5df1\u6700\u559c\u6b22\u7684\u4e13\u4e1a\u3002\u9700\u8981\u8ba4\u771f\u67e5\u770b\u7ec4\u5185\u7684\u5168\u90e8\u4e13\u4e1a\uff0c\u5e76\u6309\u7167\u6700\u4e0d\u7406\u60f3\u7684\u5f55\u53d6\u7ed3\u679c\u8fdb\u884c\u5224\u65ad\u3002\u5982\u679c\u81ea\u5df1\u65e0\u6cd5\u63a5\u53d7\u5176\u4e2d\u67d0\u4e2a\u4e13\u4e1a\uff0c\u5c31\u8981\u8c28\u614e\u8003\u8651\u662f\u5426\u586b\u62a5\u8fd9\u4e2a\u4e13\u4e1a\u7ec4\u3002\u4e0d\u8981\u628a\u201c\u5165\u5b66\u540e\u518d\u8f6c\u4e13\u4e1a\u201d\u5f53\u4f5c\u5fc5\u7136\u7684\u9000\u8def\uff0c\u56e0\u4e3a\u8f6c\u4e13\u4e1a\u901a\u5e38\u4f1a\u53d7\u5230\u6210\u7ee9\u3001\u540d\u989d\u548c\u8003\u6838\u6761\u4ef6\u7684\u9650\u5236\u3002\u540c\u65f6\uff0c\u4ee5\u524d\u51e0\u5e74\u5e7f\u897f\u7684\u62a5\u8003\u60c5\u51b5\u6765\u770b\u8bf7\u5927\u5bb6\u52a1\u5fc5\u8981\u52fe\u9009\u670d\u4ece\u8c03\u5242\u8fd9\u4e2a\u9009\u9879\uff0c\u5982\u679c\u4e0d\u52fe\u9009\u7684\u8bdd\uff0c\u5047\u5982\u4f60\u7684\u5206\u6570\u7ebf\u9ad8\u4e8e\u8be5\u6821\u7684\u6700\u9ad8\u6295\u6863\u7ebf\u4f46\u662f\u4f60\u7684\u5206\u6570\u7ebf\u4f4e\u4e8e\u4f60\u5728\u8fd9\u4e2a\u5b66\u6821\u586b\u62a5\u7684\u6240\u6709\u4e13\u4e1a\u7684\u5f55\u53d6\u5206\u6570\u7ebf\u4e14\u6ca1\u6709\u670d\u4ece\u8c03\u5242\u7684\u8bdd\uff0c\u4f60\u4f1a\u88ab\u8be5\u5927\u5b66\u9000\u6863\uff0c\u6ed1\u6863\u5230\u4e0b\u4e00\u4e2a\u6863\u6b21\uff08\u6bd4\u5982\u672c\u79d1\u6279\u5c31\u4f1a\u6ed1\u5230\u4e13\u79d1\u6279\uff09\uff0c\u6240\u4ee5\u5207\u8bb0\u4e00\u5b9a\u8981\u52fe\u9009\u4e0a\u670d\u4ece\u8c03\u5242\u3002 \u5927\u5b66\u6240\u5728\u57ce\u5e02\u4e5f\u503c\u5f97\u8003\u8651\u3002\u5927\u57ce\u5e02\u901a\u5e38\u62e5\u6709\u66f4\u591a\u4f01\u4e1a\u3001\u5b9e\u4e60\u548c\u884c\u4e1a\u6d3b\u52a8\uff0c\u4f46\u751f\u6d3b\u6210\u672c\u548c\u7ade\u4e89\u538b\u529b\u4e5f\u66f4\u9ad8\uff1b\u4e00\u4e9b\u975e\u4e00\u7ebf\u57ce\u5e02\u5219\u53ef\u80fd\u5728\u7279\u5b9a\u4ea7\u4e1a\u4e0a\u5177\u6709\u660e\u663e\u4f18\u52bf\u3002\u4e0e\u5176\u7b80\u5355\u6bd4\u8f83\u57ce\u5e02\u7b49\u7ea7\uff0c\u4e0d\u5982\u4e86\u89e3\u5f53\u5730\u662f\u5426\u6709\u4e0e\u4e13\u4e1a\u76f8\u5173\u7684\u4ea7\u4e1a\u3001\u5b66\u6821\u662f\u5426\u5177\u5907\u6821\u4f01\u5408\u4f5c\u8d44\u6e90\uff0c\u4ee5\u53ca\u81ea\u5df1\u662f\u5426\u613f\u610f\u957f\u671f\u5728\u5f53\u5730\u5b66\u4e60\u548c\u751f\u6d3b\u3002 \u5fd7\u613f\u586b\u62a5\u6d89\u53ca\u5f55\u53d6\u89c4\u5219\u7684\u5185\u5bb9\uff0c\u5e94\u4ee5\u672c\u7701\u6559\u80b2\u8003\u8bd5\u673a\u6784\u3001\u9ad8\u6821\u62db\u751f\u5b98\u7f51\u548c\u62db\u751f\u7ae0\u7a0b\u4e3a\u51c6\u3002\u91cd\u70b9\u67e5\u770b\u62db\u751f\u8ba1\u5212\u3001\u5f80\u5e74\u5f55\u53d6\u4f4d\u6b21\u3001\u4e13\u4e1a\u9009\u79d1\u8981\u6c42\u3001\u4f53\u68c0\u9650\u5236\u3001\u5355\u79d1\u6210\u7ee9\u8981\u6c42\u3001\u6536\u8d39\u6807\u51c6\u548c\u8c03\u5242\u89c4\u5219\u3002\u5c3d\u91cf\u4e0d\u8981\u4f7f\u7528\u4f20\u7edf\u7684\u51b2\u7a33\u4fdd\u7b56\u7565\uff0c\u800c\u662f\u5728\u5ba2\u89c2\u7406\u6027\u5206\u6790\u540e\u5224\u65ad\u81ea\u5df1\u7684\u5206\u6570\u80fd\u5f55\u54ea\u4e9b\u5927\u5b66\u54ea\u4e9b\u4e13\u4e1a\uff0c\u5728\u6b64\u57fa\u7840\u4e0a\u9762\u518d\u6765\u586b\u5fd7\u613f\uff0c\u8fd9\u6837\u4f1a\u5c3d\u53ef\u80fd\u88ab\u81ea\u5df1\u80fd\u591f\u63a5\u53d7\u7684\u5fd7\u613f\u5f55\u53d6\u3002</p> <p>\u6700\u540e\uff0c\u6211\u60f3\u5206\u4eab\u4e00\u4e0b\u81ea\u5df1\u5f53\u65f6\u586b\u62a5\u5fd7\u613f\u7684\u8fc7\u7a0b\u3002\u8fd9\u5e76\u4e0d\u4e00\u5b9a\u9002\u7528\u4e8e\u6240\u6709\u4eba\uff0c\u4f46\u5176\u4e2d\u7684\u4e00\u4e9b\u601d\u8def\u53ef\u4ee5\u4f5c\u4e3a\u53c2\u8003\u3002 \u9ad8\u8003\u7ed3\u675f\u540e\uff0c\u6211\u5148\u82b1\u4e86\u5927\u7ea6\u5341\u5929\u65f6\u95f4\u4e86\u89e3\u4e0d\u540c\u4e13\u4e1a\u7684\u57f9\u517b\u5185\u5bb9\u548c\u53d1\u5c55\u65b9\u5411\uff0c\u9010\u6e10\u5c06\u81ea\u5df1\u7684\u610f\u5411\u8303\u56f4\u7f29\u5c0f\u5230\u822a\u7a7a\u822a\u5929\u3001\u81ea\u52a8\u5316\u548c\u8ba1\u7b97\u673a\u4e09\u4e2a\u65b9\u5411\u3002\u5728\u6b63\u5f0f\u51fa\u5206\u524d\uff0c\u6211\u6839\u636e\u5e73\u65f6\u6a21\u62df\u8003\u8bd5\u7684\u6210\u7ee9\u548c\u5e02\u6392\u540d\uff0c\u7c97\u7565\u4f30\u8ba1\u4e86\u81ea\u5df1\u9ad8\u8003\u6210\u7ee9\u53ef\u80fd\u5bf9\u5e94\u7684\u5168\u7701\u4f4d\u6b21\u8303\u56f4\u3002\u6211\u5f53\u65f6\u4f7f\u7528\u7684\u65b9\u6cd5\uff0c\u662f\u7ed3\u5408\u672c\u5e02\u8003\u751f\u89c4\u6a21\uff0c\u5c06\u6a21\u62df\u8003\u8bd5\u7684\u5e02\u6392\u540d\u4e58\u4ee5\u5927\u7ea64\u81f35.5\uff0c\u5f97\u5230\u4e00\u4e2a\u6bd4\u8f83\u5bbd\u7684\u5168\u7701\u4f4d\u6b21\u533a\u95f4\u3002\u9700\u8981\u8bf4\u660e\u7684\u662f\uff0c\u8fd9\u53ea\u662f\u6211\u6839\u636e\u5f53\u65f6\u6240\u5728\u5730\u533a\u7684\u60c5\u51b5\u91c7\u7528\u7684\u4e2a\u4eba\u4f30\u7b97\u65b9\u6cd5\uff0c\u4e0d\u662f\u9002\u7528\u4e8e\u6240\u6709\u5730\u533a\u7684\u901a\u7528\u516c\u5f0f\u3002\u4e0d\u540c\u57ce\u5e02\u7684\u8003\u751f\u89c4\u6a21\u3001\u6a21\u62df\u8003\u8303\u56f4\u548c\u6210\u7ee9\u5206\u5e03\u5dee\u522b\u5f88\u5927\u3002\u51fa\u5206\u524d\u8fdb\u884c\u4f30\u7b97\u7684\u76ee\u7684\uff0c\u4e5f\u4e0d\u662f\u51c6\u786e\u9884\u6d4b\u81ea\u5df1\u7684\u6392\u540d\uff0c\u800c\u662f\u63d0\u524d\u5efa\u7acb\u4e00\u4e2a\u5927\u81f4\u7684\u9662\u6821\u8303\u56f4\u3002\u786e\u5b9a\u9884\u4f30\u4f4d\u6b21\u533a\u95f4\u540e\uff0c\u6211\u628a\u8fd9\u4e2a\u8303\u56f4\u5185\u53ef\u80fd\u62a5\u8003\u7684\u5b66\u6821\u5c3d\u91cf\u5217\u51fa\u6765\uff0c\u518d\u6839\u636e\u610f\u5411\u4e13\u4e1a\u3001\u6240\u5728\u57ce\u5e02\u3001\u5b66\u6821\u7684\u4f18\u52bf\u5b66\u79d1\u548c\u57f9\u517b\u7279\u70b9\u7b49\u56e0\u7d20\u8fdb\u884c\u7b2c\u4e00\u8f6e\u7b5b\u9009\u3002\u5bf9\u4e8e\u5269\u4e0b\u7684\u5b66\u6821\uff0c\u6211\u8fdb\u4e00\u6b65\u6574\u7406\u4e862022\u5e74\u81f32024\u5e74\u76f8\u5173\u4e13\u4e1a\u6216\u4e13\u4e1a\u7ec4\u7684\u5f55\u53d6\u4f4d\u6b21\u3001\u62db\u751f\u8ba1\u5212\u53ca\u5176\u6ce2\u52a8\u60c5\u51b5\uff0c\u5e76\u5236\u4f5c\u8868\u683c\u8fdb\u884c\u6bd4\u8f83\u3002\u6839\u636e\u8fd9\u4e9b\u8d44\u6599\uff0c\u6211\u4f1a\u4f30\u8ba12025\u5e74\u53ef\u80fd\u51fa\u73b0\u7684\u5f55\u53d6\u4f4d\u6b21\u533a\u95f4\uff0c\u800c\u4e0d\u662f\u53ea\u9884\u6d4b\u67d0\u4e00\u4e2a\u5177\u4f53\u540d\u6b21\u3002\u5b9e\u9645\u5f55\u53d6\u4f4d\u6b21\u4f1a\u53d7\u5230\u62db\u751f\u8ba1\u5212\u3001\u4e13\u4e1a\u7ec4\u8c03\u6574\u3001\u62a5\u8003\u70ed\u5ea6\u548c\u6240\u8c13\u201c\u5927\u5c0f\u5e74\u201d\u7b49\u56e0\u7d20\u5f71\u54cd\uff0c\u56e0\u6b64\u5f80\u5e74\u6570\u636e\u53ea\u80fd\u7528\u4e8e\u5224\u65ad\u98ce\u9669\uff0c\u4e0d\u80fd\u5f53\u4f5c\u7cbe\u786e\u7b54\u6848\u3002\u51fa\u5206\u540e\uff0c\u6211\u518d\u6839\u636e\u81ea\u5df1\u7684\u5b9e\u9645\u5168\u7701\u4f4d\u6b21\u5220\u53bb\u660e\u663e\u4e0d\u5408\u9002\u7684\u5b66\u6821\uff0c\u5e76\u5bf9\u5269\u4f59\u9662\u6821\u8fdb\u884c\u6392\u5e8f\u3002\u6392\u5e8f\u65f6\uff0c\u6211\u4e0d\u4ec5\u8003\u8651\u8fdb\u5165\u5b66\u6821\u7684\u53ef\u80fd\u6027\uff0c\u4e5f\u4f1a\u8003\u8651\u81ea\u5df1\u80fd\u5426\u63a5\u53d7\u4e13\u4e1a\u7ec4\u5185\u7684\u5176\u4ed6\u4e13\u4e1a\u3001\u5b66\u6821\u6240\u5728\u57ce\u5e02\u3001\u4e13\u4e1a\u5b9e\u529b\u4ee5\u53ca\u88ab\u8c03\u5242\u540e\u7684\u6700\u5dee\u7ed3\u679c\u3002\u7ecf\u8fc7\u8fd9\u4e9b\u6b65\u9aa4\uff0c\u6700\u7ec8\u5f62\u6210\u81ea\u5df1\u7684\u5fd7\u613f\u65b9\u6848\u3002\u6b64\u5916\uff0c\u6211\u975e\u5e38\u5efa\u8bae\u5927\u5bb6\u5173\u6ce8\u5f53\u5730\u5728\u51fa\u5206\u524d\u540e\u4e3e\u529e\u7684\u9ad8\u6821\u62db\u751f\u54a8\u8be2\u4f1a\u3002\u6842\u6797\u5f80\u5e74\u4f1a\u4e3e\u529e\u7c7b\u4f3c\u6d3b\u52a8\uff0c\u53bb\u5e74\u662f\u5728\u7532\u5929\u4e0b\u5e7f\u573a\uff0c\u53c2\u52a0\u54a8\u8be2\u4f1a\u7684\u9ad8\u6821\u8303\u56f4\u901a\u5e38\u6bd4\u8f83\u5e7f\uff0c\u4ece\u666e\u901a\u9ad8\u6821\u3001\u90e8\u5206\u201c211\u201d\u9ad8\u6821\u5230\u9876\u5c16985\u90fd\u53ef\u80fd\u8bbe\u7f6e\u54a8\u8be2\u5c55\u4f4d\u3002\u4e0e\u62db\u751f\u8001\u5e08\u9762\u5bf9\u9762\u4ea4\u6d41\uff0c\u53ef\u4ee5\u83b7\u5f97\u8bb8\u591a\u4ec5\u9760\u7f51\u4e0a\u641c\u7d22\u4e0d\u5bb9\u6613\u5224\u65ad\u7684\u4fe1\u606f\u3002\u4f8b\u5982\uff0c\u5f53\u5e74\u7684\u62db\u751f\u8ba1\u5212\u662f\u5426\u53d8\u5316\uff0c\u4e13\u4e1a\u7ec4\u600e\u6837\u8bbe\u7f6e\uff0c\u67d0\u4e2a\u4f4d\u6b21\u62a5\u8003\u5b66\u6821\u6216\u4e13\u4e1a\u7684\u98ce\u9669\u5927\u81f4\u5982\u4f55\uff0c\u4ee5\u53ca\u4e0d\u540c\u4e13\u4e1a\u5b9e\u9645\u5b66\u4e60\u54ea\u4e9b\u8bfe\u7a0b\u3002\u62db\u751f\u8001\u5e08\u5f80\u5f80\u6bd4\u8003\u751f\u66f4\u719f\u6089\u672c\u6821\u5386\u5e74\u7684\u751f\u6e90\u4f4d\u6b21\u548c\u5f53\u5e74\u7684\u54a8\u8be2\u60c5\u51b5\uff0c\u56e0\u6b64\u4ed6\u4eec\u7684\u5224\u65ad\u5f88\u6709\u53c2\u8003\u4ef7\u503c\u3002\u4e0d\u8fc7\uff0c\u8fd9\u79cd\u5224\u65ad\u4e5f\u4e0d\u662f\u5f55\u53d6\u627f\u8bfa\u3002\u6bcf\u5e74\u7684\u62a5\u8003\u4eba\u6570\u3001\u5fd7\u613f\u5206\u5e03\u548c\u62db\u751f\u653f\u7b56\u90fd\u53ef\u80fd\u53d1\u751f\u53d8\u5316\uff0c\u62db\u751f\u8001\u5e08\u540c\u6837\u65e0\u6cd5\u63d0\u524d\u51c6\u786e\u9884\u6d4b\u6700\u7ec8\u7ed3\u679c\u3002\u6211\u5f53\u65f6\u5728\u7ebf\u4e0b\u54a8\u8be2\u65f6\uff0c\u66fe\u5206\u522b\u4e0e\u590d\u65e6\u548c\u4e2d\u79d1\u5927\u7684\u62db\u751f\u8001\u5e08\u4ea4\u6d41\u3002\u4ed6\u4eec\u4e86\u89e3\u6211\u7684\u4f4d\u6b21\u548c\u610f\u5411\u540e\uff0c\u76f4\u63a5\u5efa\u8bae\u6211\u53bb\u54a8\u8be2\u4e0a\u6d77\u4ea4\u5927\u800c\u4e0d\u662f\u62a5\u590d\u65e6\u6216\u8005\u4e2d\u79d1\u5927\u3002\u6b63\u662f\u56e0\u4e3a\u8fd9\u4e2a\u5efa\u8bae\uff0c\u6211\u8fdb\u4e00\u6b65\u4e86\u89e3\u4e86\u4ea4\u5927\u7684\u57f9\u517b\u65b9\u6848\u548c\u4e13\u4e1a\u9009\u62e9\u3002\u540e\u6765\uff0c\u5728\u4e0e\u4e0a\u6d77\u4ea4\u901a\u5927\u5b66\u62db\u751f\u7ec4\u7684\u4ea4\u6d41\u4e2d\uff0c\u6211\u9010\u6e10\u660e\u786e\u4e86\u81ea\u5df1\u5bf9\u8ba1\u7b97\u673a\u65b9\u5411\u7684\u5174\u8da3\uff0c\u5e76\u6700\u7ec8\u4f5c\u51fa\u4e86\u76f8\u5e94\u9009\u62e9\u3002\u5bf9\u6211\u800c\u8a00\uff0c\u8fd9\u4e9b\u4ea4\u6d41\u4e0d\u4ec5\u63d0\u4f9b\u4e86\u5f55\u53d6\u4f4d\u6b21\u65b9\u9762\u7684\u53c2\u8003\uff0c\u4e5f\u8ba9\u6211\u5bf9\u4e13\u4e1a\u5b66\u4e60\u5185\u5bb9\u548c\u5b66\u6821\u57f9\u517b\u65b9\u5f0f\u6709\u4e86\u66f4\u5177\u4f53\u7684\u8ba4\u8bc6\uff0c\u800c\u8fd9\u4e9b\u4fe1\u606f\u4ec5\u9760\u7f51\u4e0a\u6d4f\u89c8\u5f88\u96be\u5b8c\u5168\u83b7\u5f97\u3002</p> <p>\u6ca1\u6709\u6761\u4ef6\u53c2\u52a0\u7ebf\u4e0b\u54a8\u8be2\u4f1a\u7684\u540c\u5b66\uff0c\u4e5f\u53ef\u4ee5\u4e3b\u52a8\u8054\u7cfb\u76ee\u6807\u9ad8\u6821\u7684\u62db\u751f\u8001\u5e08\u3002\u5b66\u6821\u62db\u751f\u5b98\u7f51\u3001\u5b98\u65b9\u516c\u4f17\u53f7\u6216\u5b66\u9662\u901a\u77e5\u4e2d\uff0c\u901a\u5e38\u4f1a\u516c\u5e03\u5404\u5730\u533a\u62db\u751f\u54a8\u8be2\u8054\u7cfb\u65b9\u5f0f\u3002 \u6253\u7535\u8bdd\u524d\uff0c\u5efa\u8bae\u5148\u6574\u7406\u597d\u81ea\u5df1\u7684\u7701\u4efd\u3001\u9009\u79d1\u3001\u5168\u7701\u4f4d\u6b21\u548c\u610f\u5411\u4e13\u4e1a\uff0c\u5e76\u63d0\u51fa\u5177\u4f53\u95ee\u9898\u3002\u4f8b\u5982\uff1a \u6211\u7684\u4f4d\u6b21\u62a5\u8003\u8d35\u6821\u5927\u81f4\u5904\u5728\u4ec0\u4e48\u98ce\u9669\u533a\u95f4\uff1f \u8fd9\u4e2a\u5224\u65ad\u662f\u9488\u5bf9\u5b66\u6821\u6295\u6863\uff0c\u8fd8\u662f\u67d0\u4e2a\u5177\u4f53\u4e13\u4e1a\uff1f \u4eca\u5e74\u7684\u62db\u751f\u8ba1\u5212\u548c\u4e13\u4e1a\u7ec4\u8bbe\u7f6e\u662f\u5426\u53d1\u751f\u53d8\u5316\uff1f \u4e13\u4e1a\u7ec4\u5185\u662f\u5426\u5b58\u5728\u6211\u9700\u8981\u7279\u522b\u6ce8\u610f\u7684\u4e13\u4e1a\uff1f \u662f\u5426\u5efa\u8bae\u670d\u4ece\u8c03\u5242\uff0c\u4e0d\u670d\u4ece\u8c03\u5242\u53ef\u80fd\u6709\u54ea\u4e9b\u98ce\u9669\uff1f \u76f8\u5173\u4e13\u4e1a\u4e3b\u8981\u5b66\u4e60\u4ec0\u4e48\uff0c\u5165\u5b66\u540e\u80fd\u5426\u8f6c\u4e13\u4e1a\uff1f</p> <p>\u62db\u751f\u8001\u5e08\u7684\u610f\u89c1\u4e0d\u80fd\u66ff\u4ee3\u62db\u751f\u7ae0\u7a0b\u548c\u5b98\u65b9\u5f55\u53d6\u6570\u636e\uff0c\u4f46\u5b83\u53ef\u4ee5\u5e2e\u52a9\u6211\u4eec\u66f4\u51c6\u786e\u5730\u7406\u89e3\u5b66\u6821\u5f53\u5e74\u7684\u62db\u751f\u60c5\u51b5\uff0c\u4e5f\u80fd\u53d1\u73b0\u81ea\u5df1\u539f\u672c\u6ca1\u6709\u6ce8\u610f\u5230\u7684\u4fe1\u606f\u3002\u5fd7\u613f\u586b\u62a5\u65f6\uff0c\u6700\u597d\u628a\u5386\u5e74\u6570\u636e\u3001\u5b98\u65b9\u653f\u7b56\u3001\u62db\u751f\u8001\u5e08\u7684\u610f\u89c1\u548c\u81ea\u5df1\u7684\u5b9e\u9645\u9700\u6c42\u7ed3\u5408\u8d77\u6765\uff0c\u800c\u4e0d\u662f\u53ea\u4f9d\u8d56\u5176\u4e2d\u67d0\u4e00\u79cd\u4fe1\u606f\u3002 \u5fd7\u613f\u586b\u62a5\u5f88\u96be\u627e\u5230\u4e00\u4e2a\u5404\u65b9\u9762\u90fd\u5b8c\u7f8e\u7684\u9009\u9879\u3002\u66f4\u73b0\u5b9e\u7684\u76ee\u6807\uff0c\u662f\u5728\u5145\u5206\u4e86\u89e3\u4fe1\u606f\u7684\u57fa\u7840\u4e0a\uff0c\u9009\u62e9\u4e00\u4e2a\u81ea\u5df1\u613f\u610f\u63a5\u53d7\u3001\u4e5f\u80fd\u591f\u627f\u62c5\u5176\u98ce\u9669\u7684\u65b9\u6848\u3002</p>"},{"location":"major/","title":"\u4e13\u4e1a\u8ba4\u77e5","text":""},{"location":"major/#_2","title":"#\u4e3a\u4ec0\u4e48\u8981\u4e86\u89e3\u4e13\u4e1a","text":"<p>\u4ece\u9ad8\u8003\u7ed3\u675f\u5230\u6210\u7ee9\u516c\u5e03\u3001\u5fd7\u613f\u586b\u62a5\u4e4b\u95f4\u7684\u65f6\u95f4\u5e76\u4e0d\u7b97\u957f\uff0c\u53ea\u6709\u77ed\u77ed\u4e24\u5468\u65f6\u95f4\u3002\u6211\u4eec\u9700\u8981\u5728\u8f83\u77ed\u65f6\u95f4\u5185\u4e86\u89e3\u5b66\u6821\u548c\u4e13\u4e1a\uff0c\u4f5c\u51fa\u4e00\u4e2a\u53ef\u80fd\u5f71\u54cd\u672a\u6765\u51e0\u5e74\u5b66\u4e60\u73af\u5883\u4e0e\u53d1\u5c55\u8d77\u70b9\u7684\u9009\u62e9\u3002\u8fd9\u9879\u9009\u62e9\u5f88\u91cd\u8981\uff0c\u4f46\u4e0d\u5fc5\u628a\u5b83\u7406\u89e3\u6210\u201c\u4e00\u6b21\u51b3\u5b9a\u672a\u6765\u4e8c\u5341\u5e74\u201d\u3002\u5927\u5b66\u671f\u95f4\u4ecd\u7136\u53ef\u80fd\u901a\u8fc7\u8f6c\u4e13\u4e1a\u7b49\u65b9\u5f0f\u8c03\u6574\u65b9\u5411\u3002\u73b0\u9636\u6bb5\u771f\u6b63\u9700\u8981\u505a\u7684\uff0c\u4e0d\u662f\u89c4\u5212\u5b8c\u6574\u4e2a\u4eba\u751f\uff0c\u800c\u662f\u5c3d\u53ef\u80fd\u51cf\u5c11\u76f2\u76ee\u9009\u62e9\u3002</p>"},{"location":"major/#_3","title":"\u4e86\u89e3\u4e13\u4e1a\u65f6\u5e94\u8be5\u5173\u6ce8\u4ec0\u4e48","text":"<p>\u4e86\u89e3\u4e00\u4e2a\u4e13\u4e1a\u65f6\uff0c\u4e0d\u8981\u53ea\u770b\u4e13\u4e1a\u540d\u79f0\u3001\u5f55\u53d6\u5206\u6570\u548c\u7f51\u4e0a\u6240\u8c13\u7684\u201c\u70ed\u95e8\u7a0b\u5ea6\u201d\u3002\u81f3\u5c11\u53ef\u4ee5\u5c1d\u8bd5\u56de\u7b54\u4ee5\u4e0b\u51e0\u4e2a\u95ee\u9898\uff1a</p> <ul> <li>\u8fd9\u4e2a\u4e13\u4e1a\u672c\u79d1\u9636\u6bb5\u4e3b\u8981\u5b66\u4e60\u54ea\u4e9b\u8bfe\u7a0b\uff1f\u5b83\u5bf9\u6570\u5b66\u3001\u7269\u7406\u3001\u82f1\u8bed\u3001\u7f16\u7a0b\u6216\u52a8\u624b\u80fd\u529b\u6709\u4ec0\u4e48\u8981\u6c42\uff1f</li> <li>\u65e5\u5e38\u5b66\u4e60\u66f4\u504f\u5411\u7f16\u7a0b\u3001\u5b9e\u9a8c\u3001\u80cc\u8bf5\u8fd8\u662f\u5b9e\u8df5\u64cd\u4f5c\uff1f</li> <li>\u6bd5\u4e1a\u540e\u901a\u5e38\u53ef\u4ee5\u8fdb\u5165\u54ea\u4e9b\u884c\u4e1a\u548c\u5c97\u4f4d\uff1f\u76f8\u5173\u5de5\u4f5c\u7684\u65e5\u5e38\u72b6\u6001\u662f\u4ec0\u4e48\uff0c\u662f\u5426\u9700\u8981\u51fa\u5dee\u3001\u8f6e\u73ed\u6216\u957f\u671f\u5728\u6237\u5916\u5de5\u4f5c\uff1f</li> <li>\u9664\u4e86\u76f4\u63a5\u5c31\u4e1a\uff0c\u8fd8\u53ef\u4ee5\u9009\u62e9\u54ea\u4e9b\u8003\u7814\u6216\u6df1\u9020\u65b9\u5411\uff1f\u8fd9\u4e9b\u5b66\u4e60\u5185\u5bb9\u548c\u5de5\u4f5c\u65b9\u5f0f\uff0c\u81ea\u5df1\u662f\u5426\u611f\u5174\u8da3\uff0c\u81f3\u5c11\u662f\u5426\u80fd\u591f\u63a5\u53d7\uff1f</li> </ul>"},{"location":"major/#_4","title":"\u4fe1\u606f\u5e94\u8be5\u53bb\u54ea\u91cc\u67e5","text":"<p>\u67e5\u627e\u8d44\u6599\u65f6\uff0c\u5e94\u4f18\u5148\u67e5\u770b\u5927\u5b66\u62db\u751f\u5b98\u7f51\u3001\u5b66\u9662\u5b98\u7f51\u3001\u4e13\u4e1a\u57f9\u517b\u65b9\u6848\u3001\u8bfe\u7a0b\u8bbe\u7f6e\u548c\u5b66\u6821\u53d1\u5e03\u7684\u5c31\u4e1a\u62a5\u544a\u3002\u62db\u751f\u6761\u4ef6\u3001\u4f53\u68c0\u8981\u6c42\u3001\u8f6c\u4e13\u4e1a\u653f\u7b56\u7b49\u4fe1\u606f\uff0c\u8981\u4ee5\u5b98\u65b9\u6587\u4ef6\u4e3a\u51c6\u3002</p> <p>B\u7ad9\u3001\u77e5\u4e4e\u7b49\u5e73\u53f0\u4e0a\u7684\u5728\u8bfb\u5b66\u751f\u548c\u6bd5\u4e1a\u751f\u7ecf\u9a8c\uff0c\u53ef\u4ee5\u5e2e\u52a9\u6211\u4eec\u4e86\u89e3\u8bfe\u5802\u4e4b\u5916\u7684\u771f\u5b9e\u611f\u53d7\uff0c\u4f46\u4e2a\u4eba\u7ecf\u5386\u4e0d\u80fd\u4ee3\u8868\u6574\u4e2a\u4e13\u4e1a\u3002\u5bf9\u4e8e\u201c\u8fd9\u4e2a\u4e13\u4e1a\u5343\u4e07\u4e0d\u80fd\u62a5\u201d\u201c\u6bd5\u4e1a\u5c31\u80fd\u5e74\u85aa\u591a\u5c11\u4e07\u201d\u4e4b\u7c7b\u8fc7\u4e8e\u7edd\u5bf9\u7684\u7ed3\u8bba\uff0c\u8981\u4fdd\u6301\u8c28\u614e\uff0c\u5e76\u5c3d\u91cf\u4ea4\u53c9\u6838\u5b9e\u3002 \u540c\u65f6\u4e5f\u53ef\u4ee5\u5411\u5b66\u957f\u5b66\u59d0\u4eec\u4e86\u89e3\u8fd9\u4e2a\u4e13\u4e1a\u5230\u5e95\u662f\u5728\u5b66\u4e60\u54ea\u4e9b\u65b9\u9762\u7684\u5185\u5bb9\uff0c\u5e76\u4e14\u5411\u4ed6\u4eec\u4e86\u89e3\u4e00\u4e0b\u5bf9\u5e94\u884c\u4e1a\u7684\u53d1\u5c55\u662f\u600e\u4e48\u6837\u7684</p>"},{"location":"major/#ai","title":"\u5982\u4f55\u4f7f\u7528AI","text":"<p>\u6211\u4eec\u53ef\u4ee5\u4f7f\u7528AI\u5e2e\u52a9\u89e3\u91ca\u4e00\u4e9b\u4e13\u4e1a\u7684\u964c\u751f\u6982\u5ff5\u3001\u6574\u7406\u8c03\u67e5\u95ee\u9898\uff0c\u6216\u8005\u5c06\u51e0\u4e2a\u4e13\u4e1a\u5236\u4f5c\u6210\u5bf9\u6bd4\u8868\u3002\u4e0d\u8fc7\uff0cAI\u53ef\u80fd\u51fa\u73b0\u4fe1\u606f\u8fc7\u65f6\u6216\u5185\u5bb9\u9519\u8bef\u7684\u60c5\u51b5\uff0c\u4e0d\u80fd\u66ff\u4ee3\u5b66\u6821\u5b98\u7f51\uff0c\u4e5f\u4e0d\u5e94\u8be5\u66ff\u4f60\u4f5c\u51fa\u6700\u7ec8\u51b3\u5b9a\uff0c\u5728\u8fd9\u91cc\u5e0c\u671b\u5927\u5bb6\u5c3d\u91cf\u4f7f\u7528\u7406\u6027\u4e00\u70b9\u7684AI\uff0c\u5982ChatGPT\u548cDeepSeek\u7684\u4e13\u5bb6\u7248\u672c\uff0c\u8fd9\u6837\u4fe1\u606f\u4f1a\u5c3d\u53ef\u80fd\u5168\u9762\u4e13\u4e1a\u3002 \u66f4\u65b0\uff1a\u6211\u540e\u9762\u4ee52025\u5e74\u4e0a\u6d77\u4ea4\u901a\u5927\u5b66\u672c\u79d1\u4e13\u4e1a\u4e00\u89c8\u8868\u4e3a\u57fa\u7840\uff0c\u7ed3\u54082026\u5e74\u6e05\u534e\u5927\u5b66\u672c\u79d1\u4e13\u4e1a\u8bbe\u7f6e\u4ee5\u53ca\u5317\u4eac\u5927\u5b662024\u5e74\u672c\u79d1\u751f\u62db\u751f\u4e13\u4e1a\u76ee\u5f55\u4e3a\u8865\u5145\uff0c\u4f7f\u7528\u76ee\u524d\u9876\u7ea7\u7684\u5927\u6a21\u578b\u4e4b\u4e00\uff08\u622a\u6b622026\u5e746\u67087\u53f7\uff09\u7684ChatGPT Plus\u5e2e\u5927\u5bb6\u6574\u7406\u4e86AI\u5bf9\u4e8e\u7edd\u5927\u90e8\u5206\u4e13\u4e1a\u603b\u7ed3\u5206\u6790\uff0c\u5e0c\u671b\u5bf9\u5927\u5bb6\u6709\u6240\u53c2\u8003</p> <p>\u5b87\u5b99\u514d\u8d23\u58f0\u660e:\u6b63\u5982ChatGPT\u6240\u8bf4\uff1a\u201cChatGPT\u4e5f\u53ef\u80fd\u4f1a\u72af\u9519\uff0c\u8bf7\u6838\u67e5\u91cd\u8981\u4fe1\u606f\u201d\u3002\u8fd9\u4efdAI\u5206\u6790\u7684\u4e13\u4e1a\u4ec5\u4f9b\u53c2\u8003\uff0c\u4e0d\u80fd\u4f5c\u4e3a\u9ad8\u8003\u5fd7\u613f\u586b\u62a5\u7684\u552f\u4e00\u4f9d\u636e\uff0c\u5e0c\u671b\u5927\u5bb6\u5e7f\u6cdb\u6536\u96c6\u4fe1\u606f\uff0c\u8ba4\u771f\u601d\u8003\u3002</p>"},{"location":"major/#_5","title":"\u6211\u7684\u7ecf\u5386","text":"<p>\u6211\u5728\u9ad8\u4e2d\u65f6\u671f\u5bf9\u822a\u7a7a\u822a\u5929\u6709\u7740\u5f88\u5927\u5174\u8da3\uff0c\u586b\u5fd7\u613f\u7684\u65f6\u5019\u60f3\u7740\u586b\u62a5\u822a\u7a7a\u822a\u5929\u3001\u81ea\u52a8\u5316\u4e13\u4e1a\uff0c\u4f46\u662f\u5f53\u6211\u8ddf\u4e00\u4e9b\u5b66\u957f\u5b66\u59d0\u4ea4\u6d41\u3001\u4e0a\u7f51\u67e5\u627e\u8d44\u6599\u540e\uff0c\u6211\u4e86\u89e3\u5230\u822a\u7a7a\u822a\u5929\u548c\u81ea\u52a8\u5316\u4e13\u4e1a\u5bf9\u4e8e\u7269\u7406\u7684\u8981\u6c42\u975e\u5e38\u9ad8\uff0c\u8003\u8651\u5230\u81ea\u5df1\u7684\u7269\u7406\u57fa\u7840\u5e76\u4e0d\u624e\u5b9e\uff0c\u7ecf\u8fc7\u6df1\u601d\u719f\u8651\u540e\uff0c\u6211\u8fd8\u662f\u51b3\u5b9a\u4f18\u5148\u62a5\u8003\u4e0d\u600e\u4e48\u4f9d\u8d56\u7269\u7406\u7684\u8ba1\u7b97\u673a\u4e13\u4e1a\u548c\u4eba\u5de5\u667a\u80fd\u4e13\u4e1a\uff0c\u7ecf\u8fc7\u65f6\u95f4\u8bc1\u660e\uff0c\u6211\u5f53\u65f6\u7684\u9009\u62e9\u8fd8\u662f\u6b63\u786e\u7684\uff0c\u8fd9\u4e2a\u5b66\u671f\u5b66\u4e60\u7684\u5927\u5b66\u7269\u7406\u5b66\u5f97\u6bd4\u8f83\u6323\u624e\uff0c\u4f46\u540c\u65f6\u6211\u4e5f\u53d1\u73b0\u6211\u5bf9\u4e8e</p>"},{"location":"major/#_6","title":"\u6700\u540e\u7684\u5efa\u8bae","text":"<p>\u5efa\u8bae\u9009\u51fa\u4e09\u81f3\u4e94\u4e2a\u81ea\u5df1\u53ef\u80fd\u8003\u8651\u7684\u4e13\u4e1a\uff0c\u5206\u522b\u8bb0\u5f55\u5b83\u4eec\u7684\u6838\u5fc3\u8bfe\u7a0b\u3001\u80fd\u529b\u8981\u6c42\u3001\u6df1\u9020\u65b9\u5411\u3001\u5c31\u4e1a\u9886\u57df\u548c\u5de5\u4f5c\u73af\u5883\u3002\u7ecf\u8fc7\u6bd4\u8f83\u540e\uff0c\u4e0d\u4e00\u5b9a\u80fd\u7acb\u523b\u627e\u5230\u201c\u6700\u559c\u6b22\u7684\u4e13\u4e1a\u201d\uff0c\u4f46\u81f3\u5c11\u53ef\u4ee5\u6392\u9664\u4e00\u4e9b\u660e\u663e\u4e0d\u9002\u5408\u81ea\u5df1\u7684\u9009\u62e9\uff0c\u5bf9\u5269\u4e0b\u7684\u65b9\u5411\u5f62\u6210\u66f4\u52a0\u5177\u4f53\u7684\u8ba4\u8bc6\u3002</p>"}]}